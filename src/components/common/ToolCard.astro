---
interface Props {
  name: string;
  slug: string;
  tagline: string;
  icon: string;
  isPopular?: boolean;
  isNew?: boolean;
}

const { name, slug, tagline, icon, isPopular, isNew } = Astro.props;
---

<a 
  href={`/${slug}`} 
  class="tool-card group block relative overflow-hidden transition-all duration-300 animate-fade-in-scale elevation-1 hover:elevation-4 rounded-3xl"
  aria-label={`${name} - ${tagline}`}
  data-tool-slug={slug}
  style="animation-fill-mode: both; background-color: var(--bg-elevated); border: 1px solid var(--border-primary);"
>
  <div class="relative z-10 h-full flex flex-col p-6">
    <!-- Header with icon and badges -->
    <div class="flex items-start justify-between mb-5">
      <div class="w-12 h-12 rounded-2xl flex items-center justify-center elevation-1 transition-all duration-200 group-hover:elevation-2" style="background-color: var(--bg-secondary);">
        <span 
          class="text-3xl transition-transform duration-200 group-hover:scale-110 flex-shrink-0"
          aria-hidden="true"
          style="line-height: 1;"
        >
          {icon}
        </span>
      </div>
      <div class="flex gap-1.5 items-start flex-shrink-0" aria-label={isNew && isPopular ? 'New and Popular tool' : isNew ? 'New tool' : isPopular ? 'Popular tool' : ''}>
        {isNew && (
          <span 
            class="badge-primary text-[10px] px-2.5 py-1 rounded-full font-semibold uppercase tracking-wide whitespace-nowrap" 
            aria-label="New"
          >
            New
          </span>
        )}
        {isPopular && (
          <span 
            class="badge-warning text-[10px] px-2.5 py-1 rounded-full font-semibold uppercase tracking-wide whitespace-nowrap" 
            aria-label="Popular"
          >
            Popular
          </span>
        )}
      </div>
    </div>
    
    <!-- Content area - flex-grow to push footer down -->
    <div class="flex-grow flex flex-col min-h-[80px]">
      <h3 
        class="font-semibold text-lg mb-2 transition-colors duration-200 group-hover:text-[var(--brand-primary)] line-clamp-2 leading-tight"
        style="color: var(--text-primary);"
      >
        {name}
      </h3>
      <p 
        class="text-sm line-clamp-2 leading-relaxed" 
        style="color: var(--text-muted);"
      >
        {tagline}
      </p>
    </div>
    
    <!-- Arrow indicator on hover -->
    <div class="mt-5 pt-4 border-t opacity-0 group-hover:opacity-100 transition-all duration-200 transform translate-y-2 group-hover:translate-y-0 flex items-center justify-between" style="border-color: var(--border-primary);">
      <span class="text-sm font-medium" style="color: var(--brand-primary);">Open tool</span>
      <svg class="w-5 h-5 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--brand-primary);">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </div>
  </div>
</a>



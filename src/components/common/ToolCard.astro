---
interface Props {
  name: string;
  slug: string;
  tagline: string;
  icon: string;
  isPopular?: boolean;
  isNew?: boolean;
}

const { name, slug, tagline, icon, isPopular, isNew } = Astro.props;
---

<a 
  href={`/${slug}`} 
  class="tool-card group block relative overflow-hidden transition-all duration-300 animate-fade-in-scale"
  aria-label={`${name} - ${tagline}`}
  data-tool-slug={slug}
  style="animation-fill-mode: both;"
>
  <!-- Hover gradient effect -->
  <div 
    class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"
    style="background: linear-gradient(135deg, var(--brand-primary-light) 0%, transparent 100%);"
  />
  
  <div class="relative z-10 h-full flex flex-col p-5 sm:p-6">
    <!-- Header with icon and badges -->
    <div class="flex items-start justify-between mb-4 min-h-[56px]">
      <span 
        class="text-4xl sm:text-5xl transition-all duration-300 group-hover:scale-110 group-hover:rotate-3 flex-shrink-0"
        aria-hidden="true"
        style="transform-origin: center; line-height: 1;"
      >
        {icon}
      </span>
      <div class="flex flex-col gap-1.5 items-end flex-shrink-0 ml-3" aria-label={isNew && isPopular ? 'New and Popular tool' : isNew ? 'New tool' : isPopular ? 'Popular tool' : ''}>
        {isNew && (
          <span 
            class="badge-primary text-[10px] px-2.5 py-1 rounded-full font-semibold uppercase tracking-wide shadow-sm whitespace-nowrap" 
            aria-label="New"
          >
            New
          </span>
        )}
        {isPopular && (
          <span 
            class="badge-warning text-[10px] px-2.5 py-1 rounded-full font-semibold uppercase tracking-wide shadow-sm whitespace-nowrap" 
            aria-label="Popular"
          >
            Popular
          </span>
        )}
      </div>
    </div>
    
    <!-- Content area - flex-grow to push footer down -->
    <div class="flex-grow flex flex-col min-h-[80px]">
      <h3 
        class="font-semibold text-base sm:text-lg mb-2.5 transition-all duration-200 group-hover:text-[var(--brand-primary)] line-clamp-2 leading-snug"
        style="color: var(--text-primary);"
      >
        {name}
      </h3>
      <p 
        class="text-xs sm:text-sm line-clamp-2 transition-colors duration-200 group-hover:text-[var(--text-secondary)] leading-relaxed" 
        style="color: var(--text-muted);"
      >
        {tagline}
      </p>
    </div>
    
    <!-- Arrow indicator on hover -->
    <div class="mt-4 pt-3 border-t opacity-0 group-hover:opacity-100 transition-all duration-200 transform translate-y-2 group-hover:translate-y-0 flex items-center justify-between" style="border-color: var(--border-primary);">
      <span class="text-xs font-medium" style="color: var(--brand-primary);">Open tool</span>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--brand-primary);">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </div>
  </div>
</a>



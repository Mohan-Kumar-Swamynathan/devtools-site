---
interface Props {
  slot?: 'header' | 'sidebar' | 'footer' | 'in-article';
  class?: string;
}

const { slot = 'footer', class: className = '' } = Astro.props;
const sizes: Record<string, string> = {
  header: 'h-[90px]',
  sidebar: 'h-[250px] w-full max-w-[300px]',
  footer: 'h-[90px]',
  'in-article': 'h-[250px]'
};
---

<!-- Ad Placeholder with Error Handling -->
<div 
  id={`ad-slot-${slot}`}
  class={`rounded-xl border-2 border-dashed flex items-center justify-center ${sizes[slot]} ${className}`}
  style="border-color: var(--border-primary); background-color: var(--bg-secondary);"
  data-ad-slot={slot}
>
  <span class="text-xs" style="color: var(--text-muted);">
    Advertisement
  </span>
</div>

<script is:inline define:vars={{ slot }}>
  // Handle Google Ads loading with error handling
  (function() {
    const adSlotId = `ad-slot-${slot}`;
    const adSlot = document.getElementById(adSlotId);
    if (!adSlot) return;

    // Only load Google Ads if configured (check for actual ad client ID)
    const adClient = adSlot.getAttribute('data-ad-client');
    if (!adClient || adClient.includes('XXXXXXXXXXXXXXXX')) {
      // Not configured - keep placeholder visible but don't load ads
      return;
    }

    // Load Google Ads script with error handling
    if (typeof window.adsbygoogle === 'undefined') {
      const script = document.createElement('script');
      script.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=' + encodeURIComponent(adClient);
      script.async = true;
      script.crossOrigin = 'anonymous';
      
      let loadTimeout: ReturnType<typeof setTimeout>;
      
      script.onerror = function() {
        clearTimeout(loadTimeout);
        // Silently fail - don't show error to users, just hide the ad slot
        if (adSlot) {
          adSlot.style.display = 'none';
        }
      };
      
      // Timeout after 10 seconds
      loadTimeout = setTimeout(() => {
        if (adSlot && !window.adsbygoogle) {
          adSlot.style.display = 'none';
        }
      }, 10000);
      
      script.onload = function() {
        clearTimeout(loadTimeout);
        // Initialize ad with error handling after script loads
        try {
          if (window.adsbygoogle) {
            (window.adsbygoogle = window.adsbygoogle || []).push({});
          }
        } catch (e) {
          // Silently handle initialization errors
          if (adSlot) {
            adSlot.style.display = 'none';
          }
        }
      };
      
      document.head.appendChild(script);
    } else {
      // Script already loaded, just initialize
      try {
        (window.adsbygoogle = window.adsbygoogle || []).push({});
      } catch (e) {
        if (adSlot) {
          adSlot.style.display = 'none';
        }
      }
    }
  })();
</script>


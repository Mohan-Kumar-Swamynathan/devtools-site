---
import SearchBox from '@/components/common/SearchBox.tsx';
import MobileMenu from './MobileMenu.tsx';
import HelpButton from '@/components/onboarding/HelpButton.tsx';
import { tools, categories, getToolBySlug } from '@/lib/tools';

const flowBuilderTool = getToolBySlug('flow-builder');
---

<div class="fixed top-0 left-0 right-0 z-50 flex justify-center px-4 pt-4 sm:pt-6 pointer-events-none transition-transform duration-300 transform" id="header-container">
  <header 
    class="pointer-events-auto rounded-full border backdrop-blur-xl transition-all duration-300 w-full max-w-6xl shadow-lg hover:shadow-xl" 
    style="background-color: rgba(var(--md-sys-color-surface), 0.85); border-color: var(--md-sys-color-outline-variant);"
  >
    <div class="px-3 sm:px-6">
      <div class="flex items-center justify-between h-14 sm:h-16 gap-3">
        
        <!-- Logo -->
        <a 
          href="/" 
          class="flex items-center gap-2 group transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-[var(--brand-primary)] focus:ring-offset-2 rounded-full px-2 py-1.5 hover:bg-[var(--bg-secondary)] flex-shrink-0"
          aria-label="DevTools Home"
        >
          <span class="text-2xl transition-transform duration-200 group-hover:scale-110 inline-block mb-1" role="img" aria-hidden="true">🛠️</span>
          <span class="hidden sm:inline transition-colors duration-200 font-semibold text-lg" style="color: var(--text-primary);">DevTools</span>
        </a>
        
        <!-- Desktop Navigation -->
        <nav class="hidden lg:flex items-center gap-1 xl:gap-2 overflow-x-auto no-scrollbar mask-gradient" aria-label="Main navigation">
          
          <!-- Flow Builder Featured Button -->
          {flowBuilderTool && (
            <a
              href={`/${flowBuilderTool.slug}`}
              class="flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-bold transition-all duration-200 hover:scale-105 hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-[var(--brand-primary)] focus:ring-offset-2 relative flex-shrink-0 mr-2"
              style="background: linear-gradient(135deg, var(--brand-primary) 0%, #3b82f6 100%); color: white; box-shadow: 0 2px 8px rgba(59, 130, 246, 0.25);"
              aria-label="Flow Builder"
            >
              <span class="text-base">{flowBuilderTool.icon}</span>
              <span class="whitespace-nowrap">Flow Builder</span>
              <span class="absolute -top-1 -right-1 bg-red-500 text-white text-[9px] font-bold px-1.5 py-0.5 rounded-full shadow-sm animate-pulse-slow">
                New
              </span>
            </a>
          )}

          {Object.values(categories).slice(0, 5).map((cat) => (
            <a 
              href={`/#${cat.id}`} 
              class="px-3 py-1.5 rounded-full text-sm font-medium transition-all duration-200 hover:bg-[var(--bg-secondary)] focus:outline-none focus:ring-2 focus:ring-[var(--brand-primary)] focus:ring-offset-2 whitespace-nowrap"
              style="color: var(--text-primary);"
              aria-label={`Navigate to ${cat.name}`}
            >
              {cat.name}
            </a>
          ))}
        </nav>
        
        <!-- Search + Actions -->
        <div class="flex items-center gap-2 sm:gap-3 flex-shrink-0">
          <!-- Search (Desktop) -->
          <div class="hidden md:block w-48 lg:w-64 xl:w-72 transition-all duration-300">
            <SearchBox client:load tools={tools} />
          </div>
          
          <!-- Search Icon (Mobile/Tablet) -->
          <button 
            id="mobile-search-btn"
            class="md:hidden btn-icon touch-target w-10 h-10 flex items-center justify-center rounded-full hover:bg-[var(--bg-secondary)] transition-colors"
            style="color: var(--text-primary);"
            aria-label="Search tools"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </button>
          
          <div class="w-px h-6 bg-[var(--outline-variant)] hidden sm:block"></div>
          
          <!-- Help Button -->
          <HelpButton client:load />
          

          
          <!-- Mobile Menu Button -->
          <MobileMenu client:load tools={tools} categories={Object.values(categories)} />
        </div>
      </div>
      
      <!-- Mobile Search (Expandable) -->
      <div id="mobile-search" class="md:hidden pb-4 hidden px-1 transition-all duration-300">
        <SearchBox client:load tools={tools} />
      </div>
    </div>
  </header>
</div>

<script is:inline>
  document.getElementById('mobile-search-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-search')?.classList.toggle('hidden');
  });

  // Hide header on scroll down, show on scroll up (Mobile Optimization)
  const headerContainer = document.getElementById('header-container');
  let lastScrollY = window.scrollY;
  let ticking = false;

  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        const currentScrollY = window.scrollY;
        
        if (currentScrollY > lastScrollY && currentScrollY > 100) {
          // Scrolling down
          headerContainer.style.transform = 'translateY(-120%)';
        } else {
          // Scrolling up
          headerContainer.style.transform = 'translateY(0)';
        }
        
        lastScrollY = currentScrollY;
        ticking = false;
      });
      ticking = true;
    }
  });
</script>


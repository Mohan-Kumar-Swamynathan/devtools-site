---
import ThemeToggle from './ThemeToggle.tsx';
import SearchBox from '@/components/common/SearchBox.tsx';
import MobileMenu from './MobileMenu.tsx';
import HelpButton from '@/components/onboarding/HelpButton.tsx';
import { tools, categories } from '@/lib/tools';
---

<header class="sticky top-0 z-50 border-b backdrop-blur-lg bg-opacity-80" style="background-color: var(--bg-primary); border-color: var(--border-primary);">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <div class="flex items-center justify-between h-16 sm:h-18">
      
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 font-bold text-lg sm:text-xl group">
        <span class="text-2xl sm:text-3xl transition-transform group-hover:scale-110">🛠️</span>
        <span style="color: var(--text-primary);">DevTools</span>
      </a>
      
      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1">
        {Object.values(categories).slice(0, 5).map((cat) => (
          <a 
            href={`/#${cat.id}`} 
            class="px-3 py-2 rounded-lg text-sm font-medium transition-colors hover:bg-[var(--bg-secondary)]"
            style="color: var(--text-secondary);"
          >
            {cat.name}
          </a>
        ))}
        <a 
          href="/about" 
          class="px-3 py-2 rounded-lg text-sm font-medium transition-colors hover:bg-[var(--bg-secondary)]"
          style="color: var(--text-secondary);"
        >
          About
        </a>
      </nav>
      
      <!-- Search + Actions -->
      <div class="flex items-center gap-2 sm:gap-3">
        <!-- Search (Desktop) -->
        <div class="hidden sm:block w-64 lg:w-80">
          <SearchBox client:load tools={tools} />
        </div>
        
        <!-- Search Icon (Mobile) -->
        <button 
          id="mobile-search-btn"
          class="sm:hidden btn-icon touch-target"
          aria-label="Search tools"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
        
        <!-- Help Button -->
        <HelpButton client:load />
        
        <!-- Theme Toggle -->
        <ThemeToggle client:load />
        
        <!-- Mobile Menu Button -->
        <MobileMenu client:load tools={tools} categories={Object.values(categories)} />
      </div>
    </div>
    
    <!-- Mobile Search (Expandable) -->
    <div id="mobile-search" class="sm:hidden pb-4 hidden">
      <SearchBox client:load tools={tools} />
    </div>
  </div>
</header>

<script is:inline>
  document.getElementById('mobile-search-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-search')?.classList.toggle('hidden');
  });
</script>


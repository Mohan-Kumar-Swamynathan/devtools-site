---
import { categories, tools } from '@/lib/tools';
const currentYear = new Date().getFullYear();
---

<footer class="border-t mt-20" style="background-color: var(--bg-elevated); border-color: var(--border-primary);">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-16 max-w-7xl">
    
    <!-- Tool Categories Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-8 mb-12">
      {Object.values(categories).slice(0, 5).map((category) => (
        <div>
          <h3 class="font-semibold mb-4 text-sm" style="color: var(--text-primary);">
            {category.icon} {category.name}
          </h3>
          <ul class="space-y-2">
            {tools
              .filter(t => t.category.id === category.id)
              .slice(0, 6)
              .map(tool => (
                <li>
                  <a 
                    href={`/${tool.slug}/`} 
                    class="text-sm transition-colors hover:underline"
                    style="color: var(--text-muted);"
                  >
                    {tool.name}
                  </a>
                </li>
              ))}
          </ul>
        </div>
      ))}
    </div>
    
    <!-- Bottom Section -->
    <div class="pt-8 border-t flex flex-col sm:flex-row items-center justify-between gap-4" style="border-color: var(--border-primary);">
      <!-- Logo & Copyright -->
      <div class="flex items-center gap-2">
        <span class="text-2xl">🛠️</span>
        <span class="font-semibold" style="color: var(--text-primary);">DevTools</span>
        <span class="text-sm" style="color: var(--text-muted);">
          © {currentYear}
        </span>
      </div>
      
      <!-- Links -->
      <div class="flex items-center gap-6 text-sm" style="color: var(--text-muted);">
        <a href="/about/" class="hover:underline">About</a>
        <a href="/privacy/" class="hover:underline">Privacy</a>
        <a href="/terms/" class="hover:underline">Terms</a>
        <a 
          href="https://github.com/yourusername/devtools-site" 
          target="_blank" 
          rel="noopener noreferrer"
          class="hover:underline flex items-center gap-1"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
          GitHub
        </a>
      </div>
    </div>
    
    <!-- Tagline -->
    <p class="text-center text-xs mt-6" style="color: var(--text-muted);">
      Free, fast, and private developer tools. All processing happens in your browser.
    </p>
  </div>
</footer>



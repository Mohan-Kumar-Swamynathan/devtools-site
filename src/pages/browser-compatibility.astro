---
import ToolLayout from '@/layouts/ToolLayout.astro';
import BrowserCompatibility from '@/components/tools/BrowserCompatibility.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('browser-compatibility')!;
const relatedTools = getToolsByCategory('web').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <BrowserCompatibility client:load />

  <div slot="seo-content">
    <h2>What is Browser Compatibility Checker?</h2>
    <p>
      Browser Compatibility Checker is a free online tool that checks browser compatibility for CSS properties 
      and JavaScript features across major browsers.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Check CSS feature support</li>
      <li>Check JavaScript feature support</li>
      <li>View browser version requirements</li>
      <li>Search for specific features</li>
      <li>100% client-side</li>
    </ul>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


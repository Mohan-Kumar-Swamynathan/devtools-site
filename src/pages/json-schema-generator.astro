---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsonSchemaGenerator from '@/components/tools/JsonSchemaGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('json-schema-generator')!;
const relatedTools = getToolsByCategory('json').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <JsonSchemaGenerator client:load />

  <Fragment slot="seo-content">
    <h2>What is JSON Schema Generator?</h2>
    <p>
      Automatically generate JSON Schema from JSON data. Validate JSON structure and generate schemas for documentation.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Generate JSON Schema from JSON</li>
      <li>Automatic type inference</li>
      <li>Support for nested objects and arrays</li>
      <li>Export as JSON Schema Draft 7</li>
      <li>Copy schema with one click</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>









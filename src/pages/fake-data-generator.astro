---
import ToolLayout from '@/layouts/ToolLayout.astro';
import FakeDataGenerator from '@/components/tools/FakeDataGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('fake-data-generator')!;
const relatedTools = getToolsByCategory('generators').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <FakeDataGenerator client:load />

  <Fragment slot="seo-content">
    <h2>What is Fake Data Generator?</h2>
    <p>
      Fake Data Generator is a free online tool that generates fake JSON data for testing purposes. 
      Generate names, emails, addresses, phone numbers, and more.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Generate fake JSON data</li>
      <li>Customize fields to include</li>
      <li>Generate 1-100 records</li>
      <li>Copy or download JSON</li>
      <li>100% client-side</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import FontPairingGenerator from '@/components/tools/FontPairingGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('font-pairing-generator')!;
const relatedTools = getToolsByCategory('css').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <FontPairingGenerator client:load />

  <div slot="seo-content">
    <h2>What is Font Pairing Generator?</h2>
    <p>
      Font Pairing Generator is a free online tool that generates beautiful font pairings for your designs. 
      Get suggestions for heading and body fonts.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Preset font pairings</li>
      <li>Custom font combinations</li>
      <li>Visual preview</li>
      <li>Copy generated CSS</li>
      <li>100% client-side</li>
    </ul>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


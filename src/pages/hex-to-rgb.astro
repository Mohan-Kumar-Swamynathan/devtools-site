---
import ToolLayout from '@/layouts/ToolLayout.astro';
import HexToRgb from '@/components/tools/HexToRgb.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('hex-to-rgb')!;
const relatedTools = getToolsByCategory('css').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <HexToRgb client:load />

  <Fragment slot="seo-content">
    <h2>What is Hex to RGB Converter?</h2>
    <p>
      Hex to RGB Converter is a free online tool that converts hex color codes to RGB values. 
      Get RGB, RGBA, and HSL values.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Convert hex to RGB</li>
      <li>Get RGBA values</li>
      <li>Convert to HSL</li>
      <li>Color preview</li>
      <li>100% client-side</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


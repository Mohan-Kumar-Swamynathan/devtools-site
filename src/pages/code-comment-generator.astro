---
import ToolLayout from '@/layouts/ToolLayout.astro';
import CodeCommentGenerator from '@/components/tools/CodeCommentGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('code-comment-generator')!;
const relatedTools = getToolsByCategory('documentation').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <CodeCommentGenerator client:load />

  <Fragment slot="seo-content">
    <h2>What is Code Comment Generator?</h2>
    <p>
      Generate code comments in JSDoc, inline, or block style for multiple languages. Improve code documentation.
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


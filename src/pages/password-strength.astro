---
import ToolLayout from '@/layouts/ToolLayout.astro';
import PasswordStrength from '@/components/tools/PasswordStrength';
import RelatedTools from '@/components/common/RelatedTools.astro';
import { getToolBySlug } from '@/lib/tools';

const tool = getToolBySlug('password-strength')!;
---

<ToolLayout tool={tool}>
  <PasswordStrength client:load />

  <div slot="seo-content">
    <h2>Check Your Password Security</h2>
    <p>
      Use this free online password strength checker to test how secure your passwords are. It analyzes complexity, length, and entropy to estimate how long it would take for a computer to crack it.
    </p>

    <h3>Why Password Strength Matters</h3>
    <p>
      Weak passwords are the most common entry point for cyberattacks. A strong password should:
    </p>
    <ul>
      <li>Be at least 12 characters long.</li>
      <li>Include a mix of uppercase letters, lowercase letters, numbers, and symbols.</li>
      <li>Not rely on common words or predictable patterns.</li>
    </ul>

    <div class="bg-[var(--bg-elevated)] rounded-lg p-4 border-l-4 border-green-500 mt-4">
      <strong>Privacy Note:</strong> Your password is checked locally in your browser using JavaScript. It is <strong>never</strong> sent to any server. safely.
  </div>

  <Fragment slot="related-tools">
    <RelatedTools currentToolSlug={tool.slug} category="security" />
  </div>
</ToolLayout>

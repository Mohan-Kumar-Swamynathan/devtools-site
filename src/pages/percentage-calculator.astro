---
import ToolLayout from '@/layouts/ToolLayout.astro';
import PercentageCalculator from '@/components/tools/PercentageCalculator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('percentage-calculator')!;
const relatedTools = getToolsByCategory('calculators').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <PercentageCalculator client:load />

  <div slot="seo-content">
    <h2>What is Percentage Calculator?</h2>
    <p>
      Percentage Calculator is a free online tool that calculates percentages, discounts, markups, and percentage changes. 
      Multiple calculation modes.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>What is X% of Y?</li>
      <li>Percentage increase/decrease</li>
      <li>Discount calculator</li>
      <li>Markup calculator</li>
      <li>100% client-side</li>
    </ul>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


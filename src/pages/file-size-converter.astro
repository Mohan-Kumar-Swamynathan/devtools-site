---
import ToolLayout from '@/layouts/ToolLayout.astro';
import FileSizeConverter from '@/components/tools/FileSizeConverter.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('file-size-converter')!;
const relatedTools = getToolsByCategory('file').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <FileSizeConverter client:load />

  <Fragment slot="seo-content">
    <h2>What is File Size Converter?</h2>
    <p>
      Convert file sizes between bytes, KB, MB, GB, and TB. Useful for understanding file sizes.
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


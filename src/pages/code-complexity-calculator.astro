---
import ToolLayout from '@/layouts/ToolLayout.astro';
import CodeComplexityCalculator from '@/components/tools/CodeComplexityCalculator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('code-complexity-calculator')!;
const relatedTools = getToolsByCategory('code').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <CodeComplexityCalculator client:load />

  <div slot="seo-content">
    <h2>What is Code Complexity Calculator?</h2>
    <p>
      Calculate cyclomatic complexity of code. Identify decision points and loops to measure code complexity.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


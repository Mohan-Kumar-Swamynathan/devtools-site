---
import ToolLayout from '@/layouts/ToolLayout.astro';
import Base64ImageDecoder from '@/components/tools/Base64ImageDecoder.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('base64-image-decoder')!;
const relatedTools = getToolsByCategory('encoders').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <Base64ImageDecoder client:load />

  <div slot="seo-content">
    <h2>What is Base64 Image Decoder?</h2>
    <p>
      Decode base64 encoded strings back to downloadable images. Convert base64 data URLs to image files.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import DiffChecker from '@/components/tools/DiffChecker.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('diff-checker')!;
const relatedTools = getToolsByCategory('validators').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <DiffChecker client:load />

  <div slot="seo-content">
    <h2>What is Diff Checker?</h2>
    <p>
      Compare two texts and highlight the differences. Side-by-side diff view.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


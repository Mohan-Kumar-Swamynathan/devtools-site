---
import ToolLayout from '@/layouts/ToolLayout.astro';
import CodeCommentRemover from '@/components/tools/CodeCommentRemover.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('code-comment-remover')!;
const relatedTools = getToolsByCategory('code').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <CodeCommentRemover client:load />

  <div slot="seo-content">
    <h2>What is Code Comment Remover?</h2>
    <p>
      Code Comment Remover is a free online tool that removes comments from code files. 
      Supports JavaScript, CSS, HTML, Python, and more.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Remove comments from multiple languages</li>
      <li>Supports single-line and multi-line comments</li>
      <li>Copy or download cleaned code</li>
      <li>100% client-side</li>
    </ul>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>

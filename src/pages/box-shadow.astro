---
import ToolLayout from '@/layouts/ToolLayout.astro';
import BoxShadowGenerator from '@/components/tools/BoxShadowGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('box-shadow')!;
const relatedTools = getToolsByCategory('css').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <BoxShadowGenerator client:load />

  <div slot="seo-content">
    <h2>What is Box Shadow Generator?</h2>
    <p>
      Visual CSS box shadow generator. Preview and copy CSS code.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


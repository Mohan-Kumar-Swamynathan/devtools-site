---
import ToolLayout from '@/layouts/ToolLayout.astro';
import FilenameSanitizer from '@/components/tools/FilenameSanitizer.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('filename-sanitizer')!;
const relatedTools = getToolsByCategory('file').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <FilenameSanitizer client:load />

  <div slot="seo-content">
    <h2>What is Filename Sanitizer?</h2>
    <p>
      Sanitize filenames for different operating systems. Remove invalid characters and ensure compatibility.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsonToTable from '@/components/tools/JsonToTable.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('json-to-table')!;
const relatedTools = getToolsByCategory('json').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <JsonToTable client:load />

  <Fragment slot="seo-content">
    <h2>What is JSON to Table?</h2>
    <p>
      JSON to Table is a free online tool that converts JSON data to a sortable and filterable table. 
      Visual JSON data viewer.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Convert JSON arrays to tables</li>
      <li>Sortable columns</li>
      <li>Filterable rows</li>
      <li>Automatic column detection</li>
      <li>100% client-side</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


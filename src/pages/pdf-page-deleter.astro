---
import ToolLayout from '@/layouts/ToolLayout.astro';
import PdfPageDeleter from '@/components/tools/PdfPageDeleter.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('pdf-page-deleter')!;
const relatedTools = getToolsByCategory('pdf').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <PdfPageDeleter client:load />

  <Fragment slot="seo-content">
    <h2>What is PDF Page Deleter?</h2>
    <p>
      PDF Page Deleter is a free online tool that removes pages from PDF files. 
      Delete specific pages or page ranges.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Delete pages from PDF</li>
      <li>Delete by page range or selection</li>
      <li>Download PDF with pages removed</li>
      <li>100% client-side - your files never leave your device</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


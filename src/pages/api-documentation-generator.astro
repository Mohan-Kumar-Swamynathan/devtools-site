---
import ToolLayout from '@/layouts/ToolLayout.astro';
import ApiDocumentationGenerator from '@/components/tools/ApiDocumentationGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('api-documentation-generator')!;
const relatedTools = getToolsByCategory('documentation').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <ApiDocumentationGenerator client:load />

  <div slot="seo-content">
    <h2>What is API Documentation Generator?</h2>
    <p>
      Generate API documentation in Markdown format. Includes endpoints, parameters, response examples, and curl commands.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import UuidGenerator from '@/components/tools/UuidGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('uuid-generator')!;
const relatedTools = getToolsByCategory('generators').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <UuidGenerator client:load />

  <Fragment slot="seo-content">
    <h2>What is UUID Generator?</h2>
    <p>
      UUID (Universally Unique Identifier) Generator creates unique identifiers that can be used 
      in databases, APIs, and distributed systems.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Generate UUID v4 (random)</li>
      <li>Generate multiple UUIDs at once</li>
      <li>Copy individual or all UUIDs</li>
      <li>Standard RFC 4122 compliant</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>



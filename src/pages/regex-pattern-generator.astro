---
import ToolLayout from '@/layouts/ToolLayout.astro';
import RegexPatternGenerator from '@/components/tools/RegexPatternGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('regex-pattern-generator')!;
const relatedTools = getToolsByCategory('validators').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <RegexPatternGenerator client:load />

  <div slot="seo-content">
    <h2>What is Regex Pattern Generator?</h2>
    <p>
      Regex Pattern Generator helps you create and test regular expression patterns. 
      Choose from common patterns or build your own, then test against sample text.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Common regex patterns library</li>
      <li>Test patterns against text</li>
      <li>See matches in real-time</li>
      <li>Adjustable flags (global, case-insensitive, etc.)</li>
      <li>Regex cheat sheet included</li>
    </ul>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


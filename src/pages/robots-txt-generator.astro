---
import ToolLayout from '@/layouts/ToolLayout.astro';
import RobotsTxtGenerator from '@/components/tools/RobotsTxtGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('robots-txt-generator')!;
const relatedTools = getToolsByCategory('generators').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <RobotsTxtGenerator client:load />

  <div slot="seo-content">
    <h2>What is robots.txt Generator?</h2>
    <p>
      Generate robots.txt files with custom rules for search engine crawlers. Control which parts of your site can be crawled.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


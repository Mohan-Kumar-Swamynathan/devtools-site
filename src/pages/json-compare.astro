---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsonDiff from '@/components/tools/JsonDiff'; 

import { tools } from '@/lib/tools';

const toolData = tools.find(t => t.slug === 'json-compare') || tools.find(t => t.id === 'json-compare');
---

<BaseLayout
  title={toolData?.name || 'json-compare'}
  description={toolData?.description || ''}
  toolData={toolData}
>
  <ToolLayout tool={toolData}>
    <JsonDiff client:load />
  </ToolLayout>
</BaseLayout>

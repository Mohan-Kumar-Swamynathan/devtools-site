---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JwtDecoder from '@/components/tools/JwtDecoder.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('jwt-decoder')!;
const relatedTools = getToolsByCategory('encoders').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <JwtDecoder client:load />

  <div slot="seo-content">
    <h2>What is JWT Decoder?</h2>
    <p>
      JWT (JSON Web Token) Decoder is a free tool to decode and inspect JWT tokens. 
      View the header and payload of any JWT token instantly.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Decode JWT tokens instantly</li>
      <li>View header and payload separately</li>
      <li>Check token expiration</li>
      <li>Pretty-printed JSON output</li>
    </ul>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>



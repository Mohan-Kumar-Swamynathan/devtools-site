---
import ToolLayout from '@/layouts/ToolLayout.astro';
import TextShuffler from '@/components/tools/TextShuffler.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('text-shuffler')!;
const relatedTools = getToolsByCategory('text').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <TextShuffler client:load />

  <div slot="seo-content">
    <h2>What is Text Shuffler?</h2>
    <p>
      Randomly shuffle characters, words, or lines in text. Useful for testing and obfuscation.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


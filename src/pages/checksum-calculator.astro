---
import ToolLayout from '@/layouts/ToolLayout.astro';
import ChecksumCalculator from '@/components/tools/ChecksumCalculator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('checksum-calculator')!;
const relatedTools = getToolsByCategory('security').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <ChecksumCalculator client:load />

  <Fragment slot="seo-content">
    <h2>What is Checksum Calculator?</h2>
    <p>
      Calculate SHA-1, SHA-256, and SHA-512 checksums for text data. Useful for data integrity verification.
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


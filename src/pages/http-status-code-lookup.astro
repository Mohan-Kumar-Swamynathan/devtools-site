---
import ToolLayout from '@/layouts/ToolLayout.astro';
import HttpStatusCodeLookup from '@/components/tools/HttpStatusCodeLookup.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('http-status-code-lookup')!;
const relatedTools = getToolsByCategory('network').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <HttpStatusCodeLookup client:load />

  <Fragment slot="seo-content">
    <h2>What is HTTP Status Code Lookup?</h2>
    <p>
      Lookup HTTP status codes by number. Get name, description, and category instantly.
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import TextTranslator from '@/components/tools/TextTranslator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('text-translator')!;
const relatedTools = getToolsByCategory('ai').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <TextTranslator client:load />

  <Fragment slot="seo-content">
    <h2>What is AI Text Translator?</h2>
    <p>
      AI Text Translator is a free tool that translates text between multiple languages using browser-based AI models. 
      No API keys required.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Translate text between languages</li>
      <li>Multiple language support</li>
      <li>100% browser-based - no API keys required</li>
      <li>Works offline after first load</li>
      <li>Privacy-focused - your data never leaves your device</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>



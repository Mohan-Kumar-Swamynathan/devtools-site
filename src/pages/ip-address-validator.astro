---
import ToolLayout from '@/layouts/ToolLayout.astro';
import IpAddressValidator from '@/components/tools/IpAddressValidator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('ip-address-validator')!;
const relatedTools = getToolsByCategory('validators').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <IpAddressValidator client:load />

  <Fragment slot="seo-content">
    <h2>What is IP Address Validator?</h2>
    <p>
      Validate IP addresses in both IPv4 and IPv6 formats. Check if an IP address is properly formatted 
      and determine its type.
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


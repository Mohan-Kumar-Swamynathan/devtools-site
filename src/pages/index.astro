---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ToolCard from '@/components/common/ToolCard.astro';
import AdSlot from '@/components/common/AdSlot.astro';
import { tools, categories, getPopularTools, getToolsByCategory } from '@/lib/tools';

const popularTools = getPopularTools();
---

<BaseLayout 
  title="Home"
  description="Free online developer tools - JSON formatter, Base64 encoder, JWT decoder, timestamp converter, and 50+ more tools. Fast, free, and private."
  keywords={['developer tools', 'online tools', 'json formatter', 'base64 encoder', 'jwt decoder', 'free tools']}
>
  <!-- Hero Section -->
  <section class="text-center py-12 sm:py-16 lg:py-20 relative overflow-hidden mb-12 sm:mb-16">
    <!-- Background decoration -->
    <div class="absolute inset-0 opacity-5 pointer-events-none" style="background: radial-gradient(circle at 50% 50%, var(--brand-primary) 0%, transparent 70%);" />
    
    <div class="relative z-10 max-w-4xl mx-auto">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-6 animate-fade-in leading-tight" style="color: var(--text-primary);">
        Free Developer Tools
      </h1>
      <p class="text-lg sm:text-xl lg:text-2xl max-w-2xl mx-auto mb-8 animate-fade-in font-medium" style="color: var(--text-secondary); animation-delay: 100ms;">
        Fast, free, and private. All tools run locally in your browser.
      </p>
      <div class="flex flex-wrap justify-center gap-3 sm:gap-4 text-sm animate-fade-in" style="animation-delay: 200ms;">
        <span class="flex items-center gap-2 px-4 py-2 rounded-full font-medium transition-all hover:scale-105" style="background-color: var(--bg-secondary); color: var(--text-primary); border: 1px solid var(--border-primary);">
          <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          No registration
        </span>
        <span class="flex items-center gap-2 px-4 py-2 rounded-full font-medium transition-all hover:scale-105" style="background-color: var(--bg-secondary); color: var(--text-primary); border: 1px solid var(--border-primary);">
          <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          100% Free
        </span>
        <span class="flex items-center gap-2 px-4 py-2 rounded-full font-medium transition-all hover:scale-105" style="background-color: var(--bg-secondary); color: var(--text-primary); border: 1px solid var(--border-primary);">
          <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          Voice Assistant
        </span>
      </div>
    </div>
  </section>

  <!-- Popular Tools -->
  <section class="mb-12 sm:mb-16" id="popular">
    <h2 class="text-xl sm:text-2xl font-bold mb-6 flex items-center gap-2 animate-slide-up" style="color: var(--text-primary);">
      <span class="animate-bounce">⭐</span> Popular Tools
    </h2>
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-5">
      {popularTools.slice(0, 8).map((tool, index) => (
        <div class="animate-fade-in-scale h-full" style={`animation-delay: ${index * 50}ms; animation-fill-mode: both;`}>
          <ToolCard {...tool} />
        </div>
      ))}
    </div>
  </section>

  <!-- Ad -->
  <AdSlot slot="in-article" class="mb-12 sm:mb-16" />

  <!-- All Categories -->
  {Object.values(categories).map((category, catIndex) => {
    const categoryTools = getToolsByCategory(category.id);
    if (categoryTools.length === 0) return null;
    return (
      <section class="mb-12 sm:mb-16 animate-slide-up" id={category.id} style={`animation-delay: ${catIndex * 100}ms; animation-fill-mode: both;`}>
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl sm:text-2xl lg:text-3xl font-bold flex items-center gap-3" style="color: var(--text-primary);">
            <span class="text-2xl sm:text-3xl transition-transform duration-300 hover:scale-110 hover:rotate-12 inline-block">{category.icon}</span> 
            <span>{category.name}</span>
          </h2>
          <span class="text-sm font-medium px-3 py-1 rounded-full" style="background-color: var(--bg-secondary); color: var(--text-muted);">
            {categoryTools.length} {categoryTools.length === 1 ? 'tool' : 'tools'}
          </span>
        </div>
        <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-5">
          {categoryTools.map((tool, toolIndex) => (
            <div class="animate-fade-in-scale h-full" style={`animation-delay: ${(catIndex * 50) + (toolIndex * 30)}ms; animation-fill-mode: both;`}>
              <ToolCard {...tool} />
            </div>
          ))}
        </div>
      </section>
    );
  })}
</BaseLayout>



---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ToolCard from '@/components/common/ToolCard.astro';
import { tools, categories, getPopularTools, getToolsByCategory } from '@/lib/tools';
import { ArrowRightIcon } from 'lucide-react';

const popularTools = getPopularTools();
const totalTools = tools.length;

// Categories to show with special styling
const featuredCategories = [
  { id: 'developers', name: 'Developer Tools', icon: '👨‍💻', color: 'blue' },
  { id: 'designers', name: 'Designer Tools', icon: '🎨', color: 'purple' },
  { id: 'writers', name: 'Text Tools', icon: '📝', color: 'green' },
  { id: 'converters', name: 'Converters', icon: '🔄', color: 'orange' }
];
---

<BaseLayout 
  title="Home"
  description="The ultimate developer toolkit. Free, open-source utilities for JSON, formatting, encoding, and more. 100% privacy-focused, running locally in your browser."
  keywords={['developer tools', 'web utilities', 'json formatter', 'base64 encoder', 'local dev tools', 'privacy focused']}
>
  <!-- Hero Section -->
  <section class="relative pt-24 pb-16 sm:pt-32 sm:pb-24 overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[600px] opacity-20 dark:opacity-10 bg-gradient-radial from-blue-500/40 via-purple-500/20 to-transparent blur-3xl animate-pulse-slow"></div>
      <div class="absolute inset-0 bg-[url('/grid.svg')] opacity-[0.03] dark:opacity-[0.05]"></div>
    </div>

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 text-blue-600 dark:text-blue-400 text-sm font-medium mb-8 animate-fade-in border border-blue-500/20 backdrop-blur-sm">
        <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
        v2.0 Now Available
      </div>

      <!-- Main Heading -->
      <h1 class="text-5xl sm:text-7xl lg:text-8xl font-black tracking-tight mb-8 leading-tight animate-fade-in-up" style="animation-delay: 0.1s;">
        <span class="block text-transparent bg-clip-text bg-gradient-to-br from-gray-900 via-gray-700 to-gray-500 dark:from-white dark:via-gray-200 dark:to-gray-400">
          Everything You Need.
        </span>
        <span class="block mt-2 text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-violet-600 dark:from-blue-400 dark:to-violet-400">
          Right in Your Browser.
        </span>
      </h1>

      <!-- Subtitle -->
      <p class="text-xl sm:text-2xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed animate-fade-in-up" style="animation-delay: 0.2s;">
        A premium collection of {totalTools}+ free developer tools. 
        <br class="hidden sm:block" />
        No servers. No tracking. Just pure utility.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up" style="animation-delay: 0.3s;">
        <a href="#popular" class="btn-primary-lg group min-w-[180px]">
          Start Exploring
          <svg class="w-5 h-5 group-hover:translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
        <a href="https://github.com/sanjumohan/devtools-site" target="_blank" rel="noopener noreferrer" class="btn-secondary-lg group min-w-[180px]">
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
          Star on GitHub
        </a>
      </div>

      <!-- Trust Badges -->
      <div class="mt-16 pt-8 border-t border-gray-200 dark:border-white/10 animate-fade-in-up" style="animation-delay: 0.4s;">
        <p class="text-sm font-semibold text-gray-500 uppercase tracking-widest mb-6">Trusted by developers from</p>
        <div class="flex flex-wrap justify-center gap-8 opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
          <!-- Placeholder Companies (Text for now) -->
          <span class="text-xl font-bold font-display text-gray-400">Google</span>
          <span class="text-xl font-bold font-display text-gray-400">Meta</span>
          <span class="text-xl font-bold font-display text-gray-400">Netflix</span>
          <span class="text-xl font-bold font-display text-gray-400">Vercel</span>
          <span class="text-xl font-bold font-display text-gray-400">Stripe</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular Tools Section -->
  <section id="popular" class="py-20 bg-gray-50/50 dark:bg-white/[0.02]">
    <div class="container mx-auto px-4 sm:px-6 max-w-7xl">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
            Most Popular
          </h2>
          <p class="text-lg text-gray-600 dark:text-gray-400 max-w-xl">
            The tools developers reach for every single day. Optimized for speed and productivity.
          </p>
        </div>
        <a href="#all-categories" class="text-blue-600 dark:text-blue-400 font-semibold hover:underline decoration-2 underline-offset-4 inline-flex items-center gap-2">
          View All Categories <ArrowRightIcon class="w-4 h-4" />
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {popularTools.slice(0, 8).map((tool, index) => (
          <ToolCard {...tool} class="h-full" />
        ))}
      </div>
    </div>
  </section>

  <!-- All Categories Section -->
  <section id="all-categories" class="py-20">
    <div class="container mx-auto px-4 sm:px-6 max-w-7xl">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
          Browse by Category
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400">
            Everything organized for your workflow.
        </p>
      </div>

      <div class="space-y-24">
        {Object.values(categories).map((category, catIndex) => {
          const categoryTools = getToolsByCategory(category.id);
          if (categoryTools.length === 0) return null;
          
          return (
            <div class="scroll-reveal" id={category.id}>
              <div class="flex items-center gap-4 mb-8">
                <span class="flex items-center justify-center w-12 h-12 rounded-2xl bg-gray-100 dark:bg-white/5 text-2xl shadow-sm">
                  {category.icon}
                </span>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white">
                  {category.name}
                </h3>
                <span class="ml-auto text-sm font-medium px-3 py-1 rounded-full bg-gray-100 dark:bg-white/5 text-gray-600 dark:text-gray-400">
                  {categoryTools.length} tools
                </span>
              </div>
              
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
                {categoryTools.map((tool) => (
                  <ToolCard {...tool} />
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Inline Icons Component for simpler usage -->
<script>
  // Simple Scroll Reveal API
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('reveal-visible');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
</script>

<style>
  /* Base Buttons */
  .btn-primary-lg {
    @apply inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white transition-all duration-200 bg-blue-600 rounded-full hover:bg-blue-700 hover:shadow-lg hover:shadow-blue-500/30 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500;
  }
  
  .btn-secondary-lg {
    @apply inline-flex items-center justify-center px-8 py-4 text-base font-bold text-gray-700 dark:text-gray-200 transition-all duration-200 bg-white dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-full hover:bg-gray-50 dark:hover:bg-white/10 hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500;
  }

  /* Animations */
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-fade-in-up {
    animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0; 
  }
  
  .animate-fade-in {
    animation: fade-in-up 0.8s ease-out forwards;
  }

  .scroll-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .reveal-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import PerformanceMonitor from '@/components/tools/PerformanceMonitor.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('performance-monitor')!;
const relatedTools = getToolsByCategory('code').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <PerformanceMonitor client:load />

  <div slot="seo-content">
    <h2>What is Performance Monitor?</h2>
    <p>
      Monitor browser performance metrics including memory usage, navigation timing, and resource loading. Useful for performance analysis.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import TextSummarizer from '@/components/tools/TextSummarizer.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('text-summarizer')!;
const relatedTools = getToolsByCategory('ai').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <TextSummarizer client:load />

  <Fragment slot="seo-content">
    <h2>What is AI Text Summarizer?</h2>
    <p>
      AI Text Summarizer is a free browser-based tool that uses AI to create concise summaries 
      from long articles, documents, or text. Powered by Transformers.js running entirely in your browser.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Summarize long text into key points</li>
      <li>100% browser-based - no API keys required</li>
      <li>Works offline after first load</li>
      <li>Free and open source</li>
      <li>Privacy-focused - your data never leaves your device</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>



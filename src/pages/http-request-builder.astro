---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ToolLayout from '@/layouts/ToolLayout.astro';
import ApiTester from '@/components/tools/ApiTester'; 

import { tools } from '@/lib/tools';

const toolData = tools.find(t => t.slug === 'http-request-builder') || tools.find(t => t.id === 'http-request-builder');
---

<BaseLayout
  title={toolData?.name || 'http-request-builder'}
  description={toolData?.description || ''}
  toolData={toolData}
>
  <ToolLayout tool={toolData}>
    <ApiTester client:load />
  </ToolLayout>
</BaseLayout>

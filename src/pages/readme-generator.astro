---
import ToolLayout from '@/layouts/ToolLayout.astro';
import ReadmeGenerator from '@/components/tools/ReadmeGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('readme-generator')!;
const relatedTools = getToolsByCategory('generators').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <ReadmeGenerator client:load />

  <div slot="seo-content">
    <h2>What is README Generator?</h2>
    <p>
      Generate README.md files with standard sections and formatting. Perfect for starting new projects.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import ApiTester from '@/components/tools/ApiTester.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('api-tester')!;
const relatedTools = getToolsByCategory('network').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <ApiTester client:load />

  <Fragment slot="seo-content">
    <h2>What is API Tester?</h2>
    <p>
      Test REST APIs with different HTTP methods. View responses, headers, and timing information. Perfect for API debugging.
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


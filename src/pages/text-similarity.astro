---
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('text-similarity')!;
const relatedTools = getToolsByCategory('ai').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <div class="text-center py-12">
    <p class="text-lg mb-4" style="color: var(--text-primary);">Text Similarity Checker - Coming Soon</p>
    <p class="text-sm" style="color: var(--text-muted);">This tool will be available soon. Check back later!</p>
  </div>

  <Fragment slot="seo-content">
    <h2>What is Text Similarity Checker?</h2>
    <p>
      Text Similarity Checker is a free AI tool that compares two texts and calculates similarity score. 
      Detect plagiarism, find duplicate content, or measure text similarity.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Compare two texts for similarity</li>
      <li>Calculate similarity score</li>
      <li>Detect plagiarism and duplicates</li>
      <li>100% browser-based - no API keys required</li>
      <li>Privacy-focused - your data never leaves your device</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>



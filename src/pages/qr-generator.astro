---
import ToolLayout from '@/layouts/ToolLayout.astro';
import QrGenerator from '@/components/tools/QrGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('qr-generator')!;
const relatedTools = getToolsByCategory('generators').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <QrGenerator client:load />

  <div slot="seo-content">
    <h2>What is QR Code Generator?</h2>
    <p>
      Create QR codes for URLs, text, emails, phone numbers and more. Download as PNG.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


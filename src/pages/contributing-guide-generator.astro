---
import ToolLayout from '@/layouts/ToolLayout.astro';
import ContributingGuideGenerator from '@/components/tools/ContributingGuideGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('contributing-guide-generator')!;
const relatedTools = getToolsByCategory('documentation').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <ContributingGuideGenerator client:load />

  <div slot="seo-content">
    <h2>What is Contributing Guide Generator?</h2>
    <p>
      Generate CONTRIBUTING.md files with setup instructions, code style guidelines, and testing requirements.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


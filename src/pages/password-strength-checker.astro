---
import ToolLayout from '@/layouts/ToolLayout.astro';
import PasswordStrengthChecker from '@/components/tools/PasswordStrengthChecker.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('password-strength-checker')!;
const relatedTools = getToolsByCategory('security').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <PasswordStrengthChecker client:load />

  <Fragment slot="seo-content">
    <h2>What is Password Strength Checker?</h2>
    <p>
      Password Strength Checker is a free online tool that checks password strength with visual feedback. 
      Analyze password complexity and security.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Check password strength</li>
      <li>Visual strength indicator</li>
      <li>Requirement checklist</li>
      <li>Real-time feedback</li>
      <li>100% client-side - passwords never leave your device</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>

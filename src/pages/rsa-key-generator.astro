---
import ToolLayout from '@/layouts/ToolLayout.astro';
import RsaKeyGenerator from '@/components/tools/RsaKeyGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('rsa-key-generator')!;
const relatedTools = getToolsByCategory('security').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <RsaKeyGenerator client:load />

  <div slot="seo-content">
    <h2>What is RSA Key Generator?</h2>
    <p>
      Generate RSA public and private key pairs. Keys are generated in JWK format. Keep private keys secure!
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import MorseCodeConverter from '@/components/tools/MorseCodeConverter.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('morse-code-converter')!;
const relatedTools = getToolsByCategory('encoders').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <MorseCodeConverter client:load />

  <Fragment slot="seo-content">
    <h2>What is Morse Code Converter?</h2>
    <p>
      Convert text to Morse code and decode Morse code back to text. Supports letters, numbers, and common punctuation.
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


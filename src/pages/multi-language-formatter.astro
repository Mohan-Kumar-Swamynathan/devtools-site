---
import ToolLayout from '@/layouts/ToolLayout.astro';
import MultiLanguageFormatter from '@/components/tools/MultiLanguageFormatter.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('multi-language-formatter')!;
const relatedTools = getToolsByCategory('formatters').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <MultiLanguageFormatter client:load />

  <Fragment slot="seo-content">
    <h2>What is Multi-language Code Formatter?</h2>
    <p>
      Multi-language Code Formatter is a free online tool that formats code in multiple languages. 
      Beautify and indent code automatically.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Format JSON, XML, HTML</li>
      <li>Beautify and indent code</li>
      <li>Copy or download formatted code</li>
      <li>100% client-side</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


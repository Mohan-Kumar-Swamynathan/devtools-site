---
import ToolLayout from '@/layouts/ToolLayout.astro';
import MarkdownPreview from '@/components/tools/MarkdownPreview.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('markdown-preview')!;
const relatedTools = getToolsByCategory('formatters').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <MarkdownPreview client:load />

  <Fragment slot="seo-content">
    <h2>What is Markdown Preview?</h2>
    <p>
      Live markdown editor with instant preview. Write and preview markdown simultaneously.
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


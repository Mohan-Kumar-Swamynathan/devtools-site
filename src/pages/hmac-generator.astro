---
import ToolLayout from '@/layouts/ToolLayout.astro';
import HmacGenerator from '@/components/tools/HmacGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('hmac-generator')!;
const relatedTools = getToolsByCategory('security').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <HmacGenerator client:load />

  <div slot="seo-content">
    <h2>What is HMAC Generator?</h2>
    <p>
      Generate HMAC (Hash-based Message Authentication Code) signatures using SHA-1, SHA-256, or SHA-512.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


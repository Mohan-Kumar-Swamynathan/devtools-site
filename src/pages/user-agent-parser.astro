---
import ToolLayout from '@/layouts/ToolLayout.astro';
import UserAgentParser from '@/components/tools/UserAgentParser.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('user-agent-parser')!;
const relatedTools = getToolsByCategory('web').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <UserAgentParser client:load />

  <div slot="seo-content">
    <h2>What is User Agent Parser?</h2>
    <p>
      User Agent Parser is a free online tool that parses and displays browser, device, and OS information 
      from user agent strings.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Parse user agent strings</li>
      <li>Detect browser and version</li>
      <li>Identify operating system</li>
      <li>Detect device type</li>
      <li>View rendering engine</li>
    </ul>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>

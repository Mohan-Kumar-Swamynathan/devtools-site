---
import ToolLayout from '@/layouts/ToolLayout.astro';
import DependencyParser from '@/components/tools/DependencyParser.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('dependency-parser')!;
const relatedTools = getToolsByCategory('code').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <DependencyParser client:load />

  <Fragment slot="seo-content">
    <h2>What is Dependency Parser?</h2>
    <p>
      Parse dependencies from package.json, requirements.txt, pom.xml, Cargo.toml, and more.
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


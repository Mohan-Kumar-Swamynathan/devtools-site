---
import ToolLayout from '@/layouts/ToolLayout.astro';
import TimeZoneConverter from '@/components/tools/TimeZoneConverter.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('time-zone-converter')!;
const relatedTools = getToolsByCategory('time').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <TimeZoneConverter client:load />

  <div slot="seo-content">
    <h2>What is Time Zone Converter?</h2>
    <p>
      Convert dates and times between different time zones. Supports major world time zones.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import SqlFormatter from '@/components/tools/SqlFormatter.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('sql-formatter')!;
const relatedTools = getToolsByCategory('formatters').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <SqlFormatter client:load />

  <Fragment slot="seo-content">
    <h2>What is SQL Formatter?</h2>
    <p>
      Beautify and format SQL queries with proper indentation. Supports MySQL, PostgreSQL, SQL Server.
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


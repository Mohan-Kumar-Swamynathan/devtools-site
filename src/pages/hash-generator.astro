---
import ToolLayout from '@/layouts/ToolLayout.astro';
import HashGenerator from '@/components/tools/HashGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('hash-generator')!;
const relatedTools = getToolsByCategory('generators').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <HashGenerator client:load />

  <div slot="seo-content">
    <h2>What is Hash Generator?</h2>
    <p>
      Generate cryptographic hashes online. Support for MD5, SHA-1, SHA-256, and SHA-512 algorithms.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import EnvFileValidator from '@/components/tools/EnvFileValidator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('env-file-validator')!;
const relatedTools = getToolsByCategory('validators').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <EnvFileValidator client:load />

  <div slot="seo-content">
    <h2>What is .env File Validator?</h2>
    <p>
      Validate .env files for syntax errors, duplicate keys, and best practices. Ensure your environment variables are properly formatted.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Validate .env file syntax</li>
      <li>Detect duplicate keys</li>
      <li>Check for invalid characters</li>
      <li>Warn about unquoted values</li>
      <li>Line-by-line error reporting</li>
      <li>Best practices suggestions</li>
    </ul>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>









---
import ToolLayout from '@/layouts/ToolLayout.astro';
import BarcodeGenerator from '@/components/tools/BarcodeGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('barcode-generator')!;
const relatedTools = getToolsByCategory('generators').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <BarcodeGenerator client:load />

  <div slot="seo-content">
    <h2>What is Barcode Generator?</h2>
    <p>
      Barcode Generator is a free online tool that generates barcodes in multiple formats (Code128, EAN, UPC). 
      Download as image.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Multiple barcode formats (CODE128, EAN13, EAN8, UPC, CODE39)</li>
      <li>Customizable width and height</li>
      <li>Display text option</li>
      <li>Download as PNG</li>
      <li>100% client-side</li>
    </ul>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


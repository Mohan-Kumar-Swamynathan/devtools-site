---
import ToolLayout from '@/layouts/ToolLayout.astro';
import FlowBuilder from '@/components/tools/FlowBuilder.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('flow-builder')!;
const relatedTools = getToolsByCategory('misc').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool} fullScreen={true}>
  <FlowBuilder client:load />

  <Fragment slot="seo-content">
    <h2>What is Flow Builder?</h2>
    <p>
      Flow Builder is a free, browser-based visual flowchart builder that combines Canva-level ease with Linear-level precision. 
      Create beautiful flowcharts and process diagrams with an intuitive visual canvas editor. No backend, no login, no hassle.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li><strong>Visual Canvas Editor</strong> - Click anywhere to add nodes, drag to connect them</li>
      <li><strong>Multiple Node Types</strong> - Start, End, Process, Decision, and Input/Output nodes</li>
      <li><strong>Automatic Layout</strong> - Smart positioning and edge routing for clean diagrams</li>
      <li><strong>Built-in Validation</strong> - Get helpful warnings for missing connections or invalid flows</li>
      <li><strong>Browser Storage</strong> - All diagrams saved locally in your browser</li>
      <li><strong>Export Options</strong> - Download as JSON, PNG, SVG, or Mermaid format</li>
      <li><strong>Mermaid Compatibility</strong> - Import and export Mermaid diagrams (Developer Mode)</li>
      <li><strong>100% Offline</strong> - Works without internet connection</li>
      <li><strong>No Registration</strong> - Start creating immediately, no account needed</li>
    </ul>

    <h2>How to Use</h2>
    <ol>
      <li>Click anywhere on the canvas to add a new process node</li>
      <li>Double-click any node to edit its label</li>
      <li>Drag from one node to another to create connections</li>
      <li>Use the toolbar to export your diagram or import existing files</li>
      <li>Enable Developer Mode in settings to access Mermaid import/export</li>
    </ol>

    <h2>Node Types</h2>
    <ul>
      <li><strong>Start</strong> - Beginning of your flow (rounded circle)</li>
      <li><strong>End</strong> - End of your flow (rounded circle)</li>
      <li><strong>Process</strong> - Standard process step (rectangle)</li>
      <li><strong>Decision</strong> - Decision point with multiple paths (diamond)</li>
      <li><strong>Input/Output</strong> - Data input or output (parallelogram)</li>
    </ul>

    <h2>Perfect For</h2>
    <ul>
      <li>Product managers documenting user flows</li>
      <li>Developers visualizing algorithms</li>
      <li>Business analysts mapping processes</li>
      <li>Anyone who needs to create clear, visual flowcharts</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>




---
import ToolLayout from '@/layouts/ToolLayout.astro';
import FaviconGenerator from '@/components/tools/FaviconGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('favicon-generator')!;
const relatedTools = getToolsByCategory('generators').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <FaviconGenerator client:load />

  <Fragment slot="seo-content">
    <h2>What is Favicon Generator?</h2>
    <p>
      Favicon Generator creates favicons in all required sizes from a single source image. 
      Generate 16x16, 32x32, 180x180 (Apple), 192x192 (Android), and more.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Generate multiple favicon sizes at once</li>
      <li>Support for all standard sizes</li>
      <li>Apple touch icon generation</li>
      <li>Android/PWA icon sizes</li>
      <li>Download individual or all sizes</li>
      <li>High-quality image scaling</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


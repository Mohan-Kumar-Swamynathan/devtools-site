---
import ToolLayout from '@/layouts/ToolLayout.astro';
import ColorPaletteGenerator from '@/components/tools/ColorPaletteGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('color-palette-generator')!;
const relatedTools = getToolsByCategory('css').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <ColorPaletteGenerator client:load />

  <Fragment slot="seo-content">
    <h2>What is Color Palette Generator?</h2>
    <p>
      Color Palette Generator is a free online tool that generates beautiful color palettes for your designs. 
      Create harmonious color schemes.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Generate color palettes from base color</li>
      <li>Create lighter and darker variations</li>
      <li>Copy individual colors or entire palette</li>
      <li>Export as CSS variables</li>
      <li>100% client-side</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import SpeechToText from '@/components/tools/SpeechToText.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('speech-to-text')!;
const relatedTools = getToolsByCategory('misc').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <SpeechToText client:load />

  <div slot="seo-content">
    <h2>What is Speech to Text?</h2>
    <p>
      Convert speech to text using browser-native Web Speech API. Real-time transcription as you speak. 
      Perfect for dictation, voice notes, and accessibility.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('code-explainer')!;
const relatedTools = getToolsByCategory('ai').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <div class="text-center py-12">
    <p class="text-lg mb-4" style="color: var(--text-primary);">AI Code Explainer - Coming Soon</p>
    <p class="text-sm" style="color: var(--text-muted);">This tool will be available soon. Check back later!</p>
  </div>

  <Fragment slot="seo-content">
    <h2>What is AI Code Explainer?</h2>
    <p>
      AI Code Explainer is a free tool that provides detailed explanations of code snippets in plain English. 
      Understand complex code quickly.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Explain code in plain English</li>
      <li>Understand complex code snippets</li>
      <li>100% browser-based - no API keys required</li>
      <li>Works offline after first load</li>
      <li>Privacy-focused - your code never leaves your device</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>



---
import ToolLayout from '@/layouts/ToolLayout.astro';
import TextGenerator from '@/components/tools/TextGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('text-generator')!;
const relatedTools = getToolsByCategory('ai').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <TextGenerator client:load />

  <div slot="seo-content">
    <h2>What is AI Text Generator?</h2>
    <p>
      AI Text Generator is a free tool that creates content, writes articles, generates ideas, and more 
      using open source language models running in your browser.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Generate text content</li>
      <li>Create articles and ideas</li>
      <li>100% browser-based - no API keys required</li>
      <li>Works offline after first load</li>
      <li>Privacy-focused - your data never leaves your device</li>
    </ul>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>



---
import ToolLayout from '@/layouts/ToolLayout.astro';
import PdfMerger from '@/components/tools/PdfMerger.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('pdf-merger')!;
const relatedTools = getToolsByCategory('pdf').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <PdfMerger client:load />

  <div slot="seo-content">
    <h2>What is PDF Merger?</h2>
    <p>
      PDF Merger is a free online tool that allows you to merge multiple PDF files into one. 
      Combine PDFs in any order you want.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Merge multiple PDF files</li>
      <li>Reorder PDFs before merging</li>
      <li>See page count for each PDF</li>
      <li>Download merged PDF</li>
      <li>100% client-side - your files never leave your device</li>
    </ul>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import MarkdownToHtml from '@/components/tools/MarkdownToHtml.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('markdown-to-html')!;
const relatedTools = getToolsByCategory('converters').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <MarkdownToHtml client:load />

  <Fragment slot="seo-content">
    <h2>What is Markdown to HTML Converter?</h2>
    <p>
      Convert Markdown text to HTML format. Supports all Markdown features including headers, lists, links, and code blocks.
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


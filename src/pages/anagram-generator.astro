---
import ToolLayout from '@/layouts/ToolLayout.astro';
import AnagramGenerator from '@/components/tools/AnagramGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('anagram-generator')!;
const relatedTools = getToolsByCategory('text').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <AnagramGenerator client:load />

  <div slot="seo-content">
    <h2>What is Anagram Generator?</h2>
    <p>
      Generate anagrams (rearrangements of letters) from a word. Useful for word games, puzzles, and creative writing.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


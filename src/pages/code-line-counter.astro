---
import ToolLayout from '@/layouts/ToolLayout.astro';
import CodeLineCounter from '@/components/tools/CodeLineCounter.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('code-line-counter')!;
const relatedTools = getToolsByCategory('code').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <CodeLineCounter client:load />

  <div slot="seo-content">
    <h2>What is Code Line Counter?</h2>
    <p>
      Count total lines, code lines, blank lines, comments, functions, and classes in your code.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


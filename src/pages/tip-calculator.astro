---
import ToolLayout from '@/layouts/ToolLayout.astro';
import TipCalculator from '@/components/tools/TipCalculator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('tip-calculator')!;
const relatedTools = getToolsByCategory('calculators').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <TipCalculator client:load />

  <Fragment slot="seo-content">
    <h2>What is Tip Calculator?</h2>
    <p>
      Tip Calculator is a free online tool that calculates restaurant tips with percentage and split bill functionality. 
      Perfect for dining out.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Calculate tips with customizable percentage</li>
      <li>Split bill among multiple people</li>
      <li>Quick tip percentage buttons (10%, 15%, 18%, 20%, 25%)</li>
      <li>Round up option for tips</li>
      <li>See tip and total per person</li>
      <li>100% client-side</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import UrlParser from '@/components/tools/UrlParser.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('url-parser')!;
const relatedTools = getToolsByCategory('web').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <UrlParser client:load />

  <Fragment slot="seo-content">
    <h2>What is URL Parser?</h2>
    <p>
      Parse URLs into their components: protocol, hostname, port, pathname, query parameters, and hash. 
      Useful for debugging, API development, and web scraping.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Extract all URL components</li>
      <li>Parse query parameters into JSON</li>
      <li>Display port information</li>
      <li>Show origin and host details</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


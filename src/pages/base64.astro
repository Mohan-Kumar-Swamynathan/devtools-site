---
import ToolLayout from '@/layouts/ToolLayout.astro';
import Base64 from '@/components/tools/Base64.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('base64')!;
const relatedTools = getToolsByCategory('encoders').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <Base64 client:load />

  <Fragment slot="seo-content">
    <h2>What is Base64 Encoding?</h2>
    <p>
      Base64 is a binary-to-text encoding scheme that represents binary data in an ASCII string format. 
      It's commonly used to encode data for transmission over media that are designed to deal with textual data.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Encode text to Base64</li>
      <li>Decode Base64 to text</li>
      <li>Copy results with one click</li>
      <li>Works with any text input</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>



---
import ToolLayout from '@/layouts/ToolLayout.astro';
import ChangelogGenerator from '@/components/tools/ChangelogGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('changelog-generator')!;
const relatedTools = getToolsByCategory('documentation').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <ChangelogGenerator client:load />

  <Fragment slot="seo-content">
    <h2>What is Changelog Generator?</h2>
    <p>
      Generate CHANGELOG.md files following Keep a Changelog format. Organize changes by type (Added, Changed, Fixed, etc.).
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


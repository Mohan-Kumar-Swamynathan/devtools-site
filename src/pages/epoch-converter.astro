---
import ToolLayout from '@/layouts/ToolLayout.astro';
import EpochConverter from '@/components/tools/EpochConverter.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('epoch-converter')!;
const relatedTools = getToolsByCategory('time').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <EpochConverter client:load />

  <div slot="seo-content">
    <h2>What is Epoch Converter?</h2>
    <p>
      Convert Unix epoch timestamps (seconds or milliseconds) to human-readable dates and vice versa. 
      Supports multiple date formats and time zones.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


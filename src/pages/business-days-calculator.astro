---
import ToolLayout from '@/layouts/ToolLayout.astro';
import BusinessDaysCalculator from '@/components/tools/BusinessDaysCalculator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('business-days-calculator')!;
const relatedTools = getToolsByCategory('time').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <BusinessDaysCalculator client:load />

  <Fragment slot="seo-content">
    <h2>What is Business Days Calculator?</h2>
    <p>
      Calculate the number of business days (excluding weekends) between two dates.
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


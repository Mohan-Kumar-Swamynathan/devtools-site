---
import ToolLayout from '@/layouts/ToolLayout.astro';
import WebhookTester from '@/components/tools/WebhookTester.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('webhook-tester')!;
const relatedTools = getToolsByCategory('network').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <WebhookTester client:load />

  <Fragment slot="seo-content">
    <h2>What is Webhook Payload Tester?</h2>
    <p>
      Webhook Payload Tester is a free online tool that allows you to test and validate webhook payloads. 
      Simulate webhook requests and view responses.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Test webhook endpoints</li>
      <li>Support for multiple HTTP methods</li>
      <li>Custom headers and payloads</li>
      <li>View response status and body</li>
      <li>100% client-side</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>

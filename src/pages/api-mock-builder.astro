---
import ToolLayout from '@/layouts/ToolLayout.astro';
import ApiMockBuilder from '@/components/tools/ApiMockBuilder.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('api-mock-builder')!;
const relatedTools = getToolsByCategory('network').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <ApiMockBuilder client:load />

  <div slot="seo-content">
    <h2>What is API Mock Response Builder?</h2>
    <p>
      API Mock Response Builder is a free online tool that allows you to build mock API responses for testing. 
      Create realistic JSON responses with customizable data.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Build mock API responses</li>
      <li>Add custom fields with different types</li>
      <li>Set HTTP status codes</li>
      <li>Copy or download JSON</li>
      <li>100% client-side</li>
    </ul>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import CodeSnippetGenerator from '@/components/tools/CodeSnippetGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('code-snippet-generator')!;
const relatedTools = getToolsByCategory('code').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <CodeSnippetGenerator client:load />

  <Fragment slot="seo-content">
    <h2>What is Code Snippet Generator?</h2>
    <p>
      Generate common code snippets for JavaScript, Python, HTML, and CSS. Quick templates for common patterns.
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


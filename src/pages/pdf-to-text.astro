---
import ToolLayout from '@/layouts/ToolLayout.astro';
import PdfToText from '@/components/tools/PdfToText.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('pdf-to-text')!;
const relatedTools = getToolsByCategory('pdf').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <PdfToText client:load />

  <Fragment slot="seo-content">
    <h2>What is PDF to Text?</h2>
    <p>
      PDF to Text is a free online tool that extracts text content from PDF files. 
      Copy or download extracted text.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Extract text from PDF files</li>
      <li>Preserve page structure</li>
      <li>Copy or download extracted text</li>
      <li>Support for multi-page PDFs</li>
      <li>100% client-side - your files never leave your device</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


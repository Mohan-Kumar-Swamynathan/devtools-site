---
import ToolLayout from '@/layouts/ToolLayout.astro';
import FileExtensionLookup from '@/components/tools/FileExtensionLookup.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('file-extension-lookup')!;
const relatedTools = getToolsByCategory('misc').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <FileExtensionLookup client:load />

  <div slot="seo-content">
    <h2>What is File Extension Lookup?</h2>
    <p>
      File Extension Lookup is a free online tool that allows you to lookup file extensions and their descriptions. 
      Find what file type an extension belongs to.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Lookup file extensions by name</li>
      <li>Search by extension, description, or category</li>
      <li>Copy extensions to clipboard</li>
      <li>Common file types included</li>
      <li>100% client-side</li>
    </ul>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>

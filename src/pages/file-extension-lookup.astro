---
import ToolLayout from '@/layouts/ToolLayout.astro';
import FileExtensionLookup from '@/components/tools/FileExtensionLookup.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('file-extension-lookup')!;
const relatedTools = getToolsByCategory('file').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <FileExtensionLookup client:load />

  <Fragment slot="seo-content">
    <h2>What is File Extension Lookup?</h2>
    <p>
      Lookup file extensions and their types, descriptions, and MIME types. Quick reference for file formats.
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import ResponsiveDesignTester from '@/components/tools/ResponsiveDesignTester.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('responsive-design-tester')!;
const relatedTools = getToolsByCategory('web').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <ResponsiveDesignTester client:load />

  <div slot="seo-content">
    <h2>What is Responsive Design Tester?</h2>
    <p>
      Responsive Design Tester is a free online tool that previews how your website looks on different devices 
      and screen sizes. Test responsive design with mobile, tablet, and desktop views.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Preview websites on different devices</li>
      <li>Multiple device presets (Desktop, Laptop, Tablet, Mobile)</li>
      <li>Custom viewport sizes</li>
      <li>Rotate viewport (portrait/landscape)</li>
      <li>Adjustable scale for better viewing</li>
      <li>Real-time preview</li>
      <li>100% client-side</li>
    </ul>

    <h2>Supported Devices</h2>
    <ul>
      <li>Desktop (1920×1080)</li>
      <li>Laptop (1366×768)</li>
      <li>Tablet (768×1024, 1024×768)</li>
      <li>Mobile (375×667, 667×375)</li>
      <li>iPhone 12/13 (390×844)</li>
      <li>iPhone SE (375×667)</li>
      <li>iPad (810×1080)</li>
      <li>iPad Pro (1024×1366)</li>
      <li>Custom sizes (320px - 2560px)</li>
    </ul>

    <h2>Note</h2>
    <p>
      Some websites may not load in the preview due to X-Frame-Options or Content Security Policy restrictions 
      that prevent embedding in iframes. This is a security feature implemented by those websites.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import EmojiPicker from '@/components/tools/EmojiPicker.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('emoji-picker')!;
const relatedTools = getToolsByCategory('text').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <EmojiPicker client:load />

  <Fragment slot="seo-content">
    <h2>What is Emoji Picker?</h2>
    <p>
      Emoji Picker is a free online tool that allows you to browse and copy emojis easily. 
      Search emojis by name or category.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Browse emojis by category</li>
      <li>Search emojis</li>
      <li>Copy emojis with one click</li>
      <li>Organized by categories</li>
      <li>100% client-side</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


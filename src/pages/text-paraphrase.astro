---
import ToolLayout from '@/layouts/ToolLayout.astro';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('text-paraphrase')!;
const relatedTools = getToolsByCategory('ai').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <div class="text-center py-12">
    <p class="text-lg mb-4" style="color: var(--text-primary);">Text Paraphrase Tool - Coming Soon</p>
    <p class="text-sm" style="color: var(--text-muted);">This tool will be available soon. Check back later!</p>
  </div>

  <div slot="seo-content">
    <h2>What is Text Paraphrase Tool?</h2>
    <p>
      Text Paraphrase Tool is a free AI tool that rewrites sentences and paragraphs while maintaining meaning. 
      Perfect for content creation and avoiding plagiarism.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Paraphrase text while maintaining meaning</li>
      <li>Rewrite sentences and paragraphs</li>
      <li>100% browser-based - no API keys required</li>
      <li>Works offline after first load</li>
      <li>Privacy-focused - your data never leaves your device</li>
    </ul>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>










---
import ToolLayout from '@/layouts/ToolLayout.astro';
import PathNormalizer from '@/components/tools/PathNormalizer.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('path-normalizer')!;
const relatedTools = getToolsByCategory('file').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <PathNormalizer client:load />

  <div slot="seo-content">
    <h2>What is Path Normalizer?</h2>
    <p>
      Normalize file paths for Windows or Unix/Linux systems. Convert between path formats.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


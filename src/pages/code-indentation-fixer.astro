---
import ToolLayout from '@/layouts/ToolLayout.astro';
import CodeIndentationFixer from '@/components/tools/CodeIndentationFixer.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('code-indentation-fixer')!;
const relatedTools = getToolsByCategory('code').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <CodeIndentationFixer client:load />

  <div slot="seo-content">
    <h2>What is Code Indentation Fixer?</h2>
    <p>
      Fix inconsistent indentation in code. Supports spaces and tabs. Automatically adjusts indentation levels.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import TextReplacer from '@/components/tools/TextReplacer.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('text-replacer')!;
const relatedTools = getToolsByCategory('text').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <TextReplacer client:load />

  <div slot="seo-content">
    <h2>What is Text Replacer?</h2>
    <p>
      Find and replace text with support for regular expressions. Powerful search and replace tool.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import AsciiArtGenerator from '@/components/tools/AsciiArtGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('ascii-art-generator')!;
const relatedTools = getToolsByCategory('text').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <AsciiArtGenerator client:load />

  <Fragment slot="seo-content">
    <h2>What is ASCII Art Generator?</h2>
    <p>
      Convert text to ASCII art with different font styles. Create decorative text for terminals and plain text documents.
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


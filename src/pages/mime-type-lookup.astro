---
import ToolLayout from '@/layouts/ToolLayout.astro';
import MimeTypeLookup from '@/components/tools/MimeTypeLookup.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('mime-type-lookup')!;
const relatedTools = getToolsByCategory('web').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <MimeTypeLookup client:load />

  <Fragment slot="seo-content">
    <h2>What is MIME Type Lookup?</h2>
    <p>
      MIME Type Lookup is a free online tool that allows you to lookup MIME types for file extensions. 
      Find the correct Content-Type for any file extension.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Lookup MIME types by file extension</li>
      <li>Search by extension, MIME type, or description</li>
      <li>Copy MIME types to clipboard</li>
      <li>Common file types included</li>
      <li>100% client-side</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import CompoundInterestCalculator from '@/components/tools/CompoundInterestCalculator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('compound-interest-calculator')!;
const relatedTools = getToolsByCategory('calculators').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <CompoundInterestCalculator client:load />

  <div slot="seo-content">
    <h2>What is Compound Interest Calculator?</h2>
    <p>
      Compound Interest Calculator is a free online tool that calculates compound interest over time. 
      See how your investments grow with compounding.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Calculate compound interest</li>
      <li>Multiple compounding frequencies</li>
      <li>Visual growth chart</li>
      <li>See interest earned over time</li>
      <li>100% client-side</li>
    </ul>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


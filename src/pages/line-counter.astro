---
import ToolLayout from '@/layouts/ToolLayout.astro';
import LineCounter from '@/components/tools/LineCounter.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('line-counter')!;
const relatedTools = getToolsByCategory('text').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <LineCounter client:load />

  <Fragment slot="seo-content">
    <h2>What is Line Counter?</h2>
    <p>
      Line Counter is a free online tool that counts lines, words, and characters in text. 
      Get detailed statistics about your text.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Count total lines</li>
      <li>Count non-empty and empty lines</li>
      <li>Count words and characters</li>
      <li>Count paragraphs</li>
      <li>100% client-side</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


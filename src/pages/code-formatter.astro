---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsFormatter from '@/components/tools/JsFormatter'; 

import { tools } from '@/lib/tools';

const toolData = tools.find(t => t.slug === 'code-formatter') || tools.find(t => t.id === 'code-formatter');
---

<BaseLayout
  title={toolData?.name || 'code-formatter'}
  description={toolData?.description || ''}
  toolData={toolData}
>
  <ToolLayout tool={toolData}>
    <JsFormatter client:load />
  </ToolLayout>
</BaseLayout>

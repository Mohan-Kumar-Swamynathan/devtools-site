---
import ToolLayout from '@/layouts/ToolLayout.astro';
import CreditCardValidator from '@/components/tools/CreditCardValidator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('credit-card-validator')!;
const relatedTools = getToolsByCategory('validators').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <CreditCardValidator client:load />

  <div slot="seo-content">
    <h2>What is Credit Card Validator?</h2>
    <p>
      Validate credit card numbers using the Luhn algorithm. Detects card type (Visa, Mastercard, 
      American Express, etc.). Note: This only validates format, not if the card is active.
    </p>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import TextStatistics from '@/components/tools/TextStatistics.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('text-statistics')!;
const relatedTools = getToolsByCategory('text').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <TextStatistics client:load />

  <Fragment slot="seo-content">
    <h2>What is Text Statistics Analyzer?</h2>
    <p>
      Text Statistics Analyzer is a free online tool that provides detailed text statistics including word count, 
      character count, reading time, and more.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Word and character count</li>
      <li>Paragraph and sentence count</li>
      <li>Reading time estimation</li>
      <li>Longest word finder</li>
      <li>Average word length</li>
      <li>100% client-side</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


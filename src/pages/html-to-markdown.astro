---
import ToolLayout from '@/layouts/ToolLayout.astro';
import HtmlToMarkdown from '@/components/tools/HtmlToMarkdown.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('html-to-markdown')!;
const relatedTools = getToolsByCategory('converters').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <HtmlToMarkdown client:load />

  <Fragment slot="seo-content">
    <h2>What is HTML to Markdown Converter?</h2>
    <p>
      Convert HTML to Markdown format. Preserves structure and formatting where possible.
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


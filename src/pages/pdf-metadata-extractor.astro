---
import ToolLayout from '@/layouts/ToolLayout.astro';
import PdfMetadataExtractor from '@/components/tools/PdfMetadataExtractor.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('pdf-metadata-extractor')!;
const relatedTools = getToolsByCategory('pdf').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <PdfMetadataExtractor client:load />

  <Fragment slot="seo-content">
    <h2>What is PDF Metadata Extractor?</h2>
    <p>
      PDF Metadata Extractor is a free online tool that extracts metadata from PDF files. 
      View title, author, creation date, and more.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Extract PDF metadata</li>
      <li>View title, author, subject</li>
      <li>See creation and modification dates</li>
      <li>View file size and page count</li>
      <li>100% client-side - your files never leave your device</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


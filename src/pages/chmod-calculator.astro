---
import ToolLayout from '@/layouts/ToolLayout.astro';
import ChmodCalculator from '@/components/tools/ChmodCalculator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('chmod-calculator')!;
const relatedTools = getToolsByCategory('misc').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <ChmodCalculator client:load />

  <Fragment slot="seo-content">
    <h2>What is Chmod Calculator?</h2>
    <p>
      Calculate Unix file permissions. Convert between symbolic and numeric notation.
    </p>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


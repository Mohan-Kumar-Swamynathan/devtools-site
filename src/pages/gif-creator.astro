---
import ToolLayout from '@/layouts/ToolLayout.astro';
import GifCreator from '@/components/tools/GifCreator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('gif-creator')!;
const relatedTools = getToolsByCategory('image').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <GifCreator client:load />

  <Fragment slot="seo-content">
    <h2>What is GIF Creator?</h2>
    <p>
      GIF Creator is a free online tool that allows you to create animated GIFs from multiple images. 
      Set frame delay, preview, and download your GIF.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Create animated GIFs from multiple images</li>
      <li>Adjustable frame delay (animation speed)</li>
      <li>Preview GIF before downloading</li>
      <li>Reorder or remove images before creating</li>
      <li>100% client-side - your images never leave your device</li>
    </ul>
  </Fragment>

  <Fragment slot="related-tools">
    <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
    </div>
  </Fragment>
</ToolLayout>


---
import ToolLayout from '@/layouts/ToolLayout.astro';
import ClipPathGenerator from '@/components/tools/ClipPathGenerator.tsx';
import ToolCard from '@/components/common/ToolCard.astro';
import { getToolBySlug, getToolsByCategory } from '@/lib/tools';

const tool = getToolBySlug('clip-path-generator')!;
const relatedTools = getToolsByCategory('css').filter(t => t.id !== tool.id).slice(0, 4);
---

<ToolLayout tool={tool}>
  <ClipPathGenerator client:load />

  <div slot="seo-content">
    <h2>What is Clip Path Generator?</h2>
    <p>
      Clip Path Generator is a free online tool that allows you to create CSS clip-path properties visually. 
      Create custom shapes with an interactive polygon editor.
    </p>
    
    <h2>Features</h2>
    <ul>
      <li>Create polygon clip paths</li>
      <li>Support for circle, ellipse, and inset shapes</li>
      <li>Interactive point editor</li>
      <li>Real-time preview</li>
      <li>Copy generated CSS</li>
    </ul>
  </div>

  <div slot="related-tools" class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-4">
      {relatedTools.map(t => <ToolCard {...t} />)}
  </div>
</ToolLayout>

